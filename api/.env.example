# Copy to .env and adjust. Every variable the API reads is listed here.

# Postgres connection (docker-compose maps the dev DB to host port 5433)
DATABASE_URL=postgresql+psycopg://baton:baton@localhost:5433/baton

# JWT signing secret - generate a long random string for anything beyond local dev
JWT_SECRET=change-me-in-production

# Token lifetimes
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14
SET_PASSWORD_TOKEN_TTL_HOURS=72

# CORS - the only origin allowed to call the API
FRONTEND_ORIGIN=http://localhost:5173

# Azure Communication Services email. Leave EMAIL_CONN empty for dev mode
# (emails are logged to the console instead of sent).
EMAIL_CONN=
EMAIL_FROM=DoNotReply@baton.local

# Azure Blob Storage. Leave empty for the local filesystem fallback (FILES_DIR).
AZURE_BLOB_CONN=
FILES_DIR=var/files

# Anthropic API (payment-terms polish + VAT invoice extraction, server-side only).
# Empty = those features degrade gracefully. NEVER put a real key in this file.
ANTHROPIC_API_KEY=

# Daily 07:00 Asia/Dubai overdue/receivables digest
SCHEDULER_ENABLED=true

# VAT Filing Engine (removable module) - false hides all UI and 404s its endpoints
VAT_ENGINE_ENABLED=true
VAT_EXTRACT_MAX_FILES=25

# Platform operator seeding (read once, at migration time) + trial defaults
OPERATOR_EMAIL=
OPERATOR_INITIAL_PASSWORD=
DEFAULT_TRIAL_SEATS=10
